; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="castelvania 2"
run/main_scene="uid://3r37wdox76nm"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://sprites/personagens/godot/icon.svg"

[autoload]

RigidBodyAutoScaler="*res://addons/rigidbody_auto_scaler/RigidBodyAutoScaler.gd"
Plugin="*res://addons/rigidbody_auto_scaler/plugin.gd"

[debug]

settings/profiler/max_functions=65535

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/mode=3
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/rigidbody_auto_scaler/plugin.cfg")

[file_customization]

folder_colors={
"res://readme/": "gray",
"res://scenas/": "red",
"res://scripts/": "green",
"res://sprites/": "yellow",
"res://tiles sets/": "pink"
}

